# --- Postgres (used by docker-compose and by packages/db) ---
POSTGRES_USER=scheduler
POSTGRES_PASSWORD=scheduler
POSTGRES_DB=job_scheduler
POSTGRES_PORT=5432
# Full connection string used by Prisma. When running via docker-compose,
# the host is the service name "postgres"; when running the api/worker
# locally against a dockerized Postgres, use "localhost" instead.
DATABASE_URL=postgresql://scheduler:scheduler@localhost:5432/job_scheduler?schema=public

# --- API service ---
API_PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
CRON_TICK_INTERVAL_MS=5000
DEAD_WORKER_THRESHOLD_MS=15000
DEAD_WORKER_SWEEP_INTERVAL_MS=10000
REALTIME_BROADCAST_INTERVAL_MS=2000

# --- Worker service ---
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=1000
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKER_SHUTDOWN_GRACE_MS=10000
# Comma-separated queue names this worker instance polls. Leave empty to poll all queues.
WORKER_QUEUES=

# --- Web ---
VITE_API_URL=http://localhost:4000
VITE_WS_URL=http://localhost:4000
