{
  "name": "job-scheduler-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run db:generate --if-present",
    "build": "npm run build --workspace @jobscheduler/db && npm run build --workspace @jobscheduler/shared && npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "db:generate": "npm run generate --workspace @jobscheduler/db",
    "db:migrate": "npm run migrate --workspace @jobscheduler/db",
    "db:studio": "npm run studio --workspace @jobscheduler/db",
    "dev:api": "npm run dev --workspace @jobscheduler/api",
    "dev:worker": "npm run dev --workspace @jobscheduler/worker",
    "dev:web": "npm run dev --workspace @jobscheduler/web"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
